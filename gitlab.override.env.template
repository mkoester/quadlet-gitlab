# Local overrides — values here take precedence over gitlab.env.
# This file is NOT committed to version control (see .gitignore).

# Required: GitLab Omnibus inline Ruby configuration.
# Set external_url to your public HTTPS URL.
# The nginx settings are required when TLS is terminated by a reverse proxy (e.g. Caddy).
# gitlab_shell_ssh_port must match the host port mapped to container port 22 (2222 by default).
GITLAB_OMNIBUS_CONFIG=external_url 'https://gitlab.example.com'; nginx['listen_port'] = 80; nginx['listen_https'] = false; gitlab_rails['gitlab_shell_ssh_port'] = 2222; gitlab_rails['time_zone'] = 'Europe/Berlin'; gitlab_rails['backup_keep_time'] = 604800
